pipeline{
	agent any
	stages{
		stage('checkout')
			steps{
				git url:"https://github.com/Sachin59314/Team1_dryrun_09_03.git", branch:"master"	
			 }
		stage('build & Test')
			steps{
				// Which will be defined in the pom.xml 
				sh "mvn clean package"
				
			 }
		stage('Test')
			steps{
				// Which will be defined in the pom.xml 
				sh "mvn test"
				
			 }

		stage('Deploy')
			steps{
				
			 }
		stage('Integration Tests')
			steps{
				//The integration ytest will be ran
				sh "./<testfiles>"
			 }
		}
	post{
		success{
			echo " BUild Success"
			}
		failure{
			echo "Build Failed"
		}
}
